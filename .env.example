# App — en production : https://votre-domaine.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk — https://dashboard.clerk.com
# Production : créez des clés pk_live_ / sk_live_ et ajoutez le domaine Vercel dans Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# PostgreSQL — production : Neon, Supabase ou Vercel Postgres (pas localhost)
# Neon : https://neon.tech — utilisez l'URL "pooled" pour DATABASE_URL
DATABASE_URL=postgresql://user:password@host:5432/coach_site?sslmode=require
# Optionnel (Neon) : URL directe pour prisma db push en local
# DIRECT_URL=postgresql://user:password@host:5432/coach_site?sslmode=require

# Paiements — PayZone (principal, clients Maroc)
PAYMENT_DEFAULT_PROVIDER=payzone
PAYZONE_ORIGINATOR_ID=
PAYZONE_PASSWORD=
PAYZONE_PAYMENT_URL=https://paiement.payzone.ma
PAYZONE_API_URL=https://api.payzone.ma
EUR_TO_MAD_RATE=10.85

# Paiements — Stripe (optionnel)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=ASMAE Coaching <onboarding@resend.dev>
COACH_EMAIL=contact@asmae-coaching.fr

# Visioconférence
ZOOM_STATIC_MEETING_URL=https://zoom.us/j/VOTRE_LIEN
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
GOOGLE_MEET_STATIC_URL=
