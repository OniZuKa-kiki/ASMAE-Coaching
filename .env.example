# App — en production : https://votre-domaine.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk — https://dashboard.clerk.com
# Production : créez des clés pk_live_ / sk_live_ et ajoutez le domaine Vercel dans Clerk
# Comptes démo : npm run db:seed-demo-users (voir docs/comptes-demo.md)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
# Webhook emails auth personnalisés (voir docs/clerk-emails-setup.md)
CLERK_WEBHOOK_SIGNING_SECRET=whsec_...
# auto = Resend seulement si Clerk n'a pas déjà envoyé | never = Clerk uniquement (dev)
CLERK_CUSTOM_AUTH_EMAILS=auto

# PostgreSQL — Neon
# DATABASE_URL : URL "Connection pooling" (app + Vercel)
# DIRECT_URL   : URL directe (prisma db push / migrations en local)
DATABASE_URL=postgresql://user:password@HOST-pooler.region.aws.neon.tech/neondb?sslmode=require
DIRECT_URL=postgresql://user:password@HOST.region.aws.neon.tech/neondb?sslmode=require

# Paiements — PayZone (principal, clients Maroc)
PAYMENT_DEFAULT_PROVIDER=payzone
PAYZONE_ORIGINATOR_ID=
PAYZONE_PASSWORD=
PAYZONE_PAYMENT_URL=https://paiement.payzone.ma
PAYZONE_API_URL=https://api.payzone.ma
EUR_TO_MAD_RATE=10.85

# Paiements — Stripe (optionnel)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=ASMAE Coaching <onboarding@resend.dev>
COACH_EMAIL=contact@asmae-coaching.fr

# Visioconférence
#
# ── Mode 1 : lien fixe (recommandé pour démarrer, compte Zoom gratuit OK) ──
# Même salle pour toutes les séances. Limite Zoom gratuit : ~40 min.
ZOOM_STATIC_MEETING_URL=https://zoom.us/j/VOTRE_LIEN
# Alternative Google Meet (utilisé seulement si ZOOM_STATIC_MEETING_URL est vide) :
# GOOGLE_MEET_STATIC_URL=https://meet.google.com/xxx-xxxx-xxx
#
# ── Mode 2 : Zoom dynamique (une réunion par séance) ──
# Crée automatiquement une réunion Zoom à la confirmation du paiement, avec :
#   - titre = nom du service
#   - date/heure = créneau réservé sur le site
#   - durée = durée du service (plafonnée par ZOOM_MAX_MEETING_MINUTES)
# Pour activer : remplir les 3 variables ci-dessous ET vider/commenter ZOOM_STATIC_MEETING_URL
# Prérequis : app Zoom « Server-to-Server OAuth » sur https://marketplace.zoom.us
# ZOOM_ACCOUNT_ID=
# ZOOM_CLIENT_ID=
# ZOOM_CLIENT_SECRET=
# Plafond durée API (compte Zoom gratuit ≈ 40 min) :
# ZOOM_MAX_MEETING_MINUTES=40

# Sécurité
# Chemin URL de l'admin — /admin en local, personnalisez en production
# Exemple prod : NEXT_PUBLIC_ADMIN_PATH=/console-asmae-8f3k2
NEXT_PUBLIC_ADMIN_PATH=/admin
# 2FA admin : false tant que Clerk Pro / MFA n'est pas activé
ADMIN_REQUIRE_2FA=false
# Secret pour le cron Vercel (rappels email J-1) — générez une chaîne aléatoire longue
CRON_SECRET=

# Cloudflare Turnstile (optionnel — contact)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Gemini — classification auto des thèmes de recommandation (optionnel)
# Clé gratuite : https://aistudio.google.com/
GEMINI_API_KEY=
# Modèle (défaut : gemini-3-flash-preview — gratuit, compatible free tier)
GEMINI_MODEL=gemini-3-flash-preview
# false pour désactiver le LLM et garder uniquement mots-clés + slug
USE_LLM_TOPICS=true

# Sentry — monitoring erreurs (https://sentry.io)
# Sentry — https://sentry.io
# Projet Next.js → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=
# Mettre à 1 pour envoyer les erreurs en local (npm run dev) — sinon prod uniquement
SENTRY_ENABLE_DEV=
# Optionnel — upload des source maps au build (Vercel / CI)
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Inngest — jobs async post-paiement (https://www.inngest.com)
# Guide : docs/inngest-setup.md
# Sans clés : fulfillment synchrone (fallback dev). Prod : sync app → /api/inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
